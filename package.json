{
  "name": "grand-strategy",
  "version": "0.1.2",
  "description": "A turn-based grand strategy wargame of global conquest",
  "author": "ArmadilloArmada",
  "homepage": "https://github.com/ArmadilloArmada/grand-strategy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArmadilloArmada/grand-strategy.git"
  },
  "bugs": {
    "url": "https://github.com/ArmadilloArmada/grand-strategy/issues"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:19123 && node electron/launch.cjs\"",
    "generate-icons": "node scripts/generate-icons.cjs",
    "validate:maps": "node scripts/validate-maps.js",
    "generate:mega-map": "node scripts/generate-mega-world-map.cjs",
    "update:world-map": "node scripts/update-world-map-wrap.cjs && node scripts/fix-southeast-asia-geography.cjs",
    "release:check": "npm test -- --run && npm run validate:maps && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "electron": "node electron/launch.cjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis zip && node scripts/generate-release-checksums.cjs",
    "dist:zip": "npm run build && electron-builder --win zip && node scripts/generate-release-checksums.cjs",
    "dist:portable": "npm run build && electron-builder --win portable && node scripts/generate-release-checksums.cjs",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl",
    "dist:steam": "npm run build && electron-builder --win --config electron-builder-steam.json",
    "pack:steam": "npm run build && electron-builder --win --dir --config electron-builder-steam.json",
    "release:preflight": "node scripts/release-preflight.cjs",
    "release:checksums": "node scripts/generate-release-checksums.cjs",
    "steam:preflight": "node scripts/steam-preflight.cjs",
    "steam:sync-appid": "node scripts/steam-sync-appid.cjs"
  },
  "keywords": [
    "strategy",
    "wargame",
    "turn-based",
    "game"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "steamworks.js": "^0.4.0",
    "ws": "^8.16.0"
  }
}
