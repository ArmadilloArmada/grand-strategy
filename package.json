{
  "name": "grand-strategy",
  "version": "0.1.0",
  "description": "A modern grand strategy wargame inspired by TripleA",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:19123 && node electron/launch.cjs\"",
    "dev:multiplayer": "concurrently \"vite\" \"npm run server\"",
    "server": "cd server && node index.js",
    "server:install": "cd server && npm install",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "electron": "node electron/launch.cjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl",
    "dist:steam": "npm run build && electron-builder --win --config electron-builder-steam.json"
  },
  "keywords": [
    "strategy",
    "wargame",
    "turn-based",
    "game"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.grandstrategy.game",
    "productName": "Grand Strategy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "steam_api",
        "to": "steam_api",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.strategy-games"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "LICENSE"
    },
    "forceCodeSigning": false
  }
}
